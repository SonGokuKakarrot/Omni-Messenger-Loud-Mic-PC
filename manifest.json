{
  "manifest_version": 2,
  "name": "Omni Messenger Lord",
  "short_name": "MSG Lord",
  "version": "3.0.0",
  "description": "Facebook and Messenger browser-call microphone maximizer for Android extension browsers, with page-context WebRTC hooks, live DSP controls, and a polished control panel.",
  "permissions": [
    "storage",
    "tabs",
    "https://facebook.com/*",
    "https://*.facebook.com/*",
    "https://messenger.com/*",
    "https://*.messenger.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://facebook.com/*",
        "https://*.facebook.com/*",
        "https://messenger.com/*",
        "https://*.messenger.com/*"
      ],
      "js": ["content/loader.js", "content/service.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": ["core/injector.js"],
  "browser_action": {
    "default_title": "Omni Messenger Lord",
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "omni-messenger-lord@example.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
